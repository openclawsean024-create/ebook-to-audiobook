# =============================================================================
# ebook-to-audiobook — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Supabase (optional — falls back to JSON file storage if not set)
# -----------------------------------------------------------------------------

# Your Supabase project URL.
# Found at: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (for server-side operations — KEEP SECRET).
# Found at: https://supabase.com/dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Anonymous / public key (safe to expose in client-side code).
# Found at: https://supabase.com/dashboard → Project Settings → API → anon key
SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Development-only: a shared token that bypasses Supabase JWT verification.
# DO NOT set this in production. Leave empty or remove for production.
DEV_AUTH_TOKEN=change-me-in-dev-only

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------

# Set automatically by Vercel (do not set manually).
VERCEL=1

# =============================================================================
# SUPABASE DATABASE SETUP
# =============================================================================
# If using Supabase storage, run the following in the Supabase SQL Editor:
#
# -- Users table
# CREATE TABLE IF NOT EXISTS public.users (
#   id            TEXT PRIMARY KEY,
#   email         TEXT,
#   plan          TEXT NOT NULL DEFAULT 'free',
#   usage_chars   BIGINT NOT NULL DEFAULT 0,
#   usage_conversions BIGINT NOT NULL DEFAULT 0,
#   api_key       TEXT,
#   api_key_created_at TIMESTAMPTZ,
#   created_at    TIMESTAMPTZ NOT NULL DEFAULT now(),
#   updated_at    TIMESTAMPTZ NOT NULL DEFAULT now(),
#   usage_period_start TIMESTAMPTZ DEFAULT EXTRACT(EPOCH FROM now())::bigint
# );
#
# -- Jobs table
# CREATE TABLE IF NOT EXISTS public.jobs (
#   job_id        TEXT PRIMARY KEY,
#   user_id       TEXT NOT NULL,
#   status        TEXT NOT NULL DEFAULT 'queued',
#   stage         TEXT NOT NULL DEFAULT 'queued',
#   progress      INTEGER NOT NULL DEFAULT 0,
#   title         TEXT DEFAULT 'Unknown',
#   author        TEXT DEFAULT 'Unknown Author',
#   file_type     TEXT DEFAULT '',
#   voice         TEXT DEFAULT 'zh-CN-XiaoxiaoNeural',
#   rate          TEXT DEFAULT '+0%',
#   volume        TEXT DEFAULT '+0%',
#   text_chars    BIGINT DEFAULT 0,
#   chapter_count INTEGER DEFAULT 0,
#   segment_count INTEGER DEFAULT 0,
#   bundle_type   TEXT,
#   merge_strategy TEXT,
#   download_url  TEXT,
#   merged_download_url TEXT,
#   zip_download_url TEXT,
#   manifest_download_url TEXT,
#   chapter_files JSONB DEFAULT '[]',
#   chapters      JSONB DEFAULT '[]',
#   segments      JSONB DEFAULT '[]',
#   message       TEXT,
#   error         TEXT,
#   created_at    TIMESTAMPTZ NOT NULL DEFAULT now(),
#   updated_at    TIMESTAMPTZ NOT NULL DEFAULT now(),
#   completed_at  TIMESTAMPTZ
# );
#
# -- Rate limits table
# CREATE TABLE IF NOT EXISTS public.rate_limits (
#   identifier    TEXT PRIMARY KEY,
#   count         BIGINT NOT NULL DEFAULT 0,
#   window_start  BIGINT NOT NULL DEFAULT 0
# );
#
# -- RLS policies (enable after creating tables)
# ALTER TABLE public.users ENABLE ROW LEVEL SECURITY;
# ALTER TABLE public.jobs ENABLE ROW LEVEL SECURITY;
# ALTER TABLE public.rate_limits ENABLE ROW LEVEL SECURITY;
#
# -- Users: users can read/update their own record
# CREATE POLICY "users_own_record" ON public.users
#   FOR ALL USING (auth.uid()::text = id);
#
# -- Jobs: users can read/write their own jobs
# CREATE POLICY "jobs_own" ON public.jobs
#   FOR ALL USING (user_id = auth.uid()::text);
#
# =============================================================================
